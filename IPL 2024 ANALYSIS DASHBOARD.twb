      <aliases enabled='yes' />
      <column caption='SRH Matches' datatype='boolean' name='[Calculation_1282873758195713]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[team1]= &quot;SRH&quot; OR [team2] = &quot;SRH&quot;' />
      </column>
      <column caption='Match Category' datatype='string' name='[Calculation_1282874032484357]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [team1_score] &gt;= 200 THEN&#13;&#10;    &quot;High Scoring&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Champions' datatype='string' name='[Calculation_1282874034679814]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;KKR&quot;' />
      </column>
      <column caption='SRH matches' datatype='integer' name='[Calculation_1282874036748295]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [team1] = &quot;SRH&quot;&#13;&#10;OR [team2] = &quot;SRH&quot;&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='SRH Wins' datatype='integer' name='[Calculation_1282874036850696]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [winner] = &quot;SRH&quot;&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='SRH Win Rate' datatype='real' default-format='p0%' name='[Calculation_1282874036977673]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1282874036850696]) / SUM([Calculation_1282874036748295])' />
      </column>
      <column caption='Toss Win Match WIn' datatype='integer' name='[Calculation_1282874059644938]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [toss_winner] = [winner] THEN&#13;&#10;    1&#13;&#10;ELSE&#13;&#10;    0&#13;&#10;END' />
      </column>
      <column caption='Toss Impact %' datatype='real' default-format='p0%' name='[Calculation_1282874059714571]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1282874059644938]) / COUNT([match_id])' />
      </column>
      <column caption='ipl_2024_matches.csv' datatype='table' name='[__tableau_internal_object_id__].[ipl_2024_matches.csv_E039718C02EF4DE18B4D83F041242EB0]' role='measure' type='quantitative' />
